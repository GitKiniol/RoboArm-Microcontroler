     516:	30 97       	sbiw	r30, 0x00	; 0
     518:	41 f7       	brne	.-48     	; 0x4ea <Data_ClearJob+0x12>
	{
		Data_ClearList(Job->Current->Data);							/* zwolnij pamięć zajmowana przez sublistę												*/
		Job->Current = Job->Current->Next;							/* przesuń wskaźnik na element następny													*/
	}
	Data_ClearList(Job);											/* zwolnij pamięć zajmowaną przez listę JOB												*/
